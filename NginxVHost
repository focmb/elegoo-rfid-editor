server {

    listen 443 ssl;
    http2 on;
    server_name rfideditor.domain.de;
    ssl_certificate ...;  #add your certicate path here - path to fullchain.pem file
    ssl_certificate_key ...; # and here - path to privkey.pem

    # Wichtig für Web NFC: HSTS schadet nicht, ist aber optional
    add_header Strict-Transport-Security "max-age=31536000" always;

    location / {
        # Basic auth if you make the editor reachable from the internet
        # sudo apt install apache2-utils   # if htpasswd is missing
        # sudo htpasswd -c /etc/nginx/.htpasswd username
        auth_basic           "Zugang erforderlich";
        auth_basic_user_file /etc/nginx/.htpasswd;
        proxy_pass http://172.16.1.4:8092;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

     location /spoolman/ {
        proxy_pass http://172.16.1.4:7912/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
